# ============================================================
# 本地開發環境變數
# ============================================================
# 複製此檔案為 .env 並填入你的值
#
# 部署時請參考：
# - Deno Deploy: .env.deno-deploy.example
# - Fly.io:      .env.fly.example
# - 完整教學:    docs/DEPLOYMENT.md
# ============================================================

# Database (Turso / LibSQL)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# AI Processing (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-api-key-here
# Optional: override model (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Hard daily spend cap in USD for AI summarize/translate calls (crawler + reindex scripts stop when hit)
AI_DAILY_BUDGET_USD=0.50

# Vector Store (ChromaDB)
CHROMA_HOST=http://localhost:8000
CHROMA_AUTH_TOKEN=astrogroot-token

# Optional: Redis (for task queues)
REDIS_URL=redis://localhost:6379

# Data Sources
NASA_API_KEY=DEMO_KEY
# Get your key at: https://api.nasa.gov/

# YouTube Data API v3 (required for video collection)
# Get your key at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Server Configuration
PORT=8000
ENVIRONMENT=development

# Background Worker Settings
CRAWLER_INTERVAL_HOURS=72
# 10 recommended for arXiv stability; increase if APIs are stable
MAX_ITEMS_PER_SOURCE=10
# MCP Server Settings
MCP_SERVER_NAME=astrogroot-library
MCP_SERVER_VERSION=1.0.0
